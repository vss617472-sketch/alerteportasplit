modules = ["nodejs-20", "web", "bash"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
POLAR_PRODUCT_ID = "0358546f-1871-4769-80e7-dfcb7cddd8ab"
FROM_EMAIL = "onboarding@resend.dev"

[userenv.production]
APP_URL = "https://radar-analysis-suite--vss617472.replit.app"
